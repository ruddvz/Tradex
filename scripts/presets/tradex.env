# Tradex — non-interactive preset for Claude Company OS
# Usage: source scripts/presets/tradex.env && bash scripts/setup.sh --apply-only
# Or: bash scripts/setup.sh --preset tradex

export COMPANY_OS_PRESET=tradex

export COMPANY_NAME="Tradex"
export PRODUCT_DESCRIPTION="AI-powered trading journal for Forex, gold (XAUUSD), indices, and stocks, with MT5 sync, analytics, and prop-firm tracking."
export CUSTOMER_DESCRIPTION="Retail and prop-firm traders who journal trades and want performance and psychology insights."
export STAGE="Active development — UI + API foundation shipped; auth, real DB, and integrations per NEXT_STEPS.md"

export LANG="TypeScript, Python"
export FRONTEND="React 19, Vite 8, Tailwind CSS 3, React Router 7, Zustand, Recharts"
export BACKEND="FastAPI (Python 3.12), Uvicorn"
export DATABASE="PostgreSQL, Redis (cache and Celery)"
export AUTH="JWT + passlib (Phase 1 in NEXT_STEPS.md)"
export PAYMENTS="none"
export EMAIL="Planned: SendGrid or SMTP (Phase 4)"
export HOSTING="Docker Compose, Nginx reverse proxy"
export TESTING="pytest (backend), ESLint (frontend); add Vitest/Playwright as the suite grows"
export KEY_SERVICES="OpenAI (AI insights), MetaTrader5 (sync), Celery (background jobs)"

export TEST_CMD="cd backend && pytest -q; cd ../frontend && npm run lint"
export BUILD_CMD="cd frontend && npm run build"
export DEV_CMD="docker-compose up -d (full stack) OR cd frontend && npm run dev (UI only)"
export MAIN_BRANCH="main"

export HAS_FRONTEND=Y
export HAS_BACKEND=Y
export HAS_OPS=Y
export HAS_DATA=Y
