# Tradex Backend Environment Variables

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/tradex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI (optional — enables AI insights) ───────────────────────────────────
OPENAI_API_KEY=

# ── MetaTrader 5 (optional — enables auto-sync) ───────────────────────────────
MT5_SERVER=Exness-MT5Real
MT5_LOGIN=
MT5_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Daily email reports (Phase 4) ─────────────────────────────────────────────
# Leave SMTP_HOST empty for dev — digests are skipped but Celery task still runs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=Tradex <noreply@tradex.local>
# Hour (0–23 UTC) when Celery beat runs send_daily_reports (user-local 8 PM needs timezone field).
DAILY_REPORT_HOUR_UTC=20
# Required for POST /api/v1/notifications/send-daily when DEBUG=false
NOTIFICATIONS_CRON_SECRET=
