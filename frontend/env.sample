# Frontend (Vite) — copy lines into `.env` locally if you override defaults.
#
# Authentication — defaults suit a personal install (full app, no sign-in screen).
# Set VITE_AUTH_UI_ENABLED=true to expose `/auth` (sign-in / register).
# Set VITE_REQUIRE_LOGIN=true to block the shell until JWT (use with auth UI).
VITE_AUTH_UI_ENABLED=false
VITE_REQUIRE_LOGIN=false
